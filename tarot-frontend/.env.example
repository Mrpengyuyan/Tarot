# 前端环境配置示例文件
# 复制此文件为 .env.local 并填入真实配置

# API 基础URL
REACT_APP_API_BASE_URL=http://localhost:8000/api/v1

# Coze AI 配置
REACT_APP_COZE_API_URL=https://api.coze.cn/open_api/v2
REACT_APP_COZE_BOT_ID=your_bot_id_here
REACT_APP_COZE_ACCESS_TOKEN=your_access_token_here

# 应用配置
REACT_APP_NAME=神秘塔罗
REACT_APP_VERSION=1.0.0
REACT_APP_DESCRIPTION=AI驱动的专业塔罗占卜平台

# 功能开关
REACT_APP_ENABLE_3D=true
REACT_APP_ENABLE_ANIMATIONS=true
REACT_APP_ENABLE_SOUND=false
REACT_APP_DEBUG_MODE=false

# 第三方服务
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_SENTRY_DSN=

# 开发配置
GENERATE_SOURCEMAP=true
ESLINT_NO_DEV_ERRORS=true
FAST_REFRESH=true